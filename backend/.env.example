# ══════════════════════════════════════════
# Churn Dashboard — Environment Variables
# ══════════════════════════════════════════
# Copy file ini menjadi .env dan isi nilainya.

# ── MySQL ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=churn_dashboard

# ── LLM Provider (OpenAI-compatible) ──
# Ganti base_url dan model jika menggunakan provider lain.
# Contoh provider lain:
#   DeepSeek langsung: https://api.deepseek.com | deepseek-chat
#   OpenAI:            https://api.openai.com/v1 | gpt-4o-mini
#   Groq:              https://api.groq.com/openai/v1 | llama-3.1-70b-versatile
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://tokenhub-intl.tencentcloudmaas.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ── JWT ──
JWT_SECRET=change-me-in-production

# ── Admin Seeding ──
# Admin default dibuat saat tabel users kosong.
ADMIN_EMAIL=admin@churndashboard.com
ADMIN_PASSWORD=your_admin_password_here

# ── Flask ──
FLASK_DEBUG=true
